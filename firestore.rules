rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Dados isolados por usuário ────────────────────────────────────────────
    // Cada usuário só acessa seus próprios dados em /users/{uid}/**
    // Isso cobre clients, contracts e installments de forma automática.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Coleções globais antigas (legado) ────────────────────────────────────
    // Mantidas para não quebrar dados existentes, mas sem acesso de escrita.
    match /clients/{clientId} {
      allow read: if request.auth != null;
      allow write: if false; // bloqueado — use /users/{uid}/clients
    }

    match /contracts/{contractId} {
      allow read: if request.auth != null;
      allow write: if false; // bloqueado — use /users/{uid}/contracts
    }

    match /installments/{installmentId} {
      allow read: if request.auth != null;
      allow write: if false; // bloqueado — use /users/{uid}/installments
    }
  }
}

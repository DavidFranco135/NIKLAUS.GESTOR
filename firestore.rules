rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidClient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 3 &&
             data.document is string && data.document.size() >= 11;
    }

    function isValidContract(data) {
      return data.clientId is string &&
             data.totalAmount is number && data.totalAmount > 0 &&
             data.installmentsCount is int && data.installmentsCount > 0 &&
             data.status in ['active', 'completed', 'cancelled'];
    }

    function isValidInstallment(data) {
      return data.contractId is string &&
             data.number is int && data.number > 0 &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'paid', 'overdue'];
    }

    match /clients/{clientId} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidClient(request.resource.data);
    }

    match /contracts/{contractId} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidContract(request.resource.data);
    }

    match /installments/{installmentId} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidInstallment(request.resource.data);
    }
  }
}
